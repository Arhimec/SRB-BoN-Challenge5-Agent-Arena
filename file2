import fetch from 'node-fetch';
import { BON_EXPLORER_API, BON_GATEWAY_API, TARGET_ADDRESS } from '../src/config';

export async function getBonHealth() {
  const now = Date.now();
  let explorerOk = false;
  let gatewayOk = false;

  try {
    const res = await fetch(${BON_EXPLORER_API}/accounts/${TARGET_ADDRESS}/transactions?size=1);
    explorerOk = res.ok;
  } catch {
    explorerOk = false;
  }

  try {
    const res = await fetch(${BON_GATEWAY_API}/network/config);
    gatewayOk = res.ok;
  } catch {
    gatewayOk = false;
  }

  return { explorerOk, gatewayOk, checkedAt: now };
}

// FILE: dashboard/prometheus.ts
import client from 'prom-client';
import { computeGuildMetrics } from './metricsHub';

const registry = new client.Registry();
client.collectDefaultMetrics({ register: registry });

const gauge = new client.Gauge({
  name: 'guild_metrics',
  help: 'Guild-wide metrics',
  labelNames: ['metric'],
});

registry.registerMetric(gauge);

export function updatePrometheus() {
  const guild = computeGuildMetrics();
  gauge.set({ metric: 'total_score' }, guild.totalScore);
  gauge.set({ metric: 'total_fee' }, guild.totalFeeSpent);
  gauge.set({ metric: 'active_agents' }, guild.activeAgents);
}

export function prometheusHandler(_req: any, res: any) {
  updatePrometheus();
  res.set('Content-Type', registry.contentType);
  res.end(registry.metrics());
}
