import React, { useEffect, useState } from 'react';
import GuildSummary from './components/GuildSummary';
import AgentGrid from './components/AgentGrid';
import Alerts from './components/Alerts';
import Charts from './components/Charts';
import BonHealth from './components/BonHealth';

const App: React.FC = () => {
  const [snapshot, setSnapshot] = useState<any | null>(null);

  useEffect(() => {
    const ws = new WebSocket(ws://${window.location.hostname}:4000);
    ws.onmessage = ev => {
      const data = JSON.parse(ev.data);
      if (data.type === 'snapshot') setSnapshot(data);
    };
    return () => ws.close();
  }, []);

  if (!snapshot) return <div>Loading dashboard…</div>;
  return (
    <div style={{ display: 'flex', gap: 16, padding: 16, fontFamily: 'sans-serif', background: '#111', color: '#eee' }}>
      <div style={{ flex: 1, display: 'flex', flexDirection: 'column', gap: 16 }}>
        <GuildSummary guild={snapshot.guild} globalState={snapshot.globalState} admin={snapshot.admin} guildFeeSpent={snapshot.guildFeeSpent} />
        <BonHealth />
        <Alerts agents={snapshot.agents} guildFeeSpent={snapshot.guildFeeSpent} />
      </div>
      <div style={{ flex: 2, display: 'flex', flexDirection: 'column', gap: 16 }}>
        <AgentGrid agents={snapshot.agents} />
        <Charts agents={snapshot.agents} />
      </div>
    </div>
  );
};

export default App;

