import express from 'express';
import http from 'http';
import WebSocket from 'ws';
import { DASHBOARD_PORT } from '../src/config';
import { getAllAgentMetrics, computeGuildMetrics, updateAgentMetrics } from './metricsHub';
import { getBonHealth } from './bonHealth';
import { prometheusHandler } from './prometheus';
import { getGlobalState, getAdminContext } from '../src/globalState';
import { getGuildFeeSpent } from '../src/globalFee';
import { log } from '../src/logger';

export { updateAgentMetrics };

export function startDashboardServer() {
  const app = express();
  const server = http.createServer(app);
  const wss = new WebSocket.Server({ server });

  app.get('/metrics', prometheusHandler);

  app.get('/bon-health', async (_req, res) => {
    const health = await getBonHealth();
    res.json(health);
  });

  wss.on('connection', ws => {
    const sendSnapshot = async () => {
      const agents = getAllAgentMetrics();
      const guild = computeGuildMetrics();
      const health = await getBonHealth();
      const globalState = getGlobalState();
      const admin = getAdminContext();
      const guildFeeSpent = getGuildFeeSpent();
      ws.send(
        JSON.stringify({
          type: 'snapshot',
          agents,
          guild,
          health,
          globalState,
          admin,
          guildFeeSpent,
        })
      );
    };
    sendSnapshot();
    const id = setInterval(sendSnapshot, 1000);
    ws.on('close', () => clearInterval(id));
  });

  server.listen(DASHBOARD_PORT, () => {
    log([dashboard] listening on ${DASHBOARD_PORT});
  });
}

