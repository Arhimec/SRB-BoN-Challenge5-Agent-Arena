import React, { useEffect, useState } from 'react';
interface BonHealthState {
  explorerOk: boolean;
  gatewayOk: boolean;
  checkedAt: number;
}

const BonHealth: React.FC = () => {
  const [health, setHealth] = useState<BonHealthState | null>(null);

  useEffect(() => {
    const fetchHealth = async () => {
      try {
        const res = await fetch('/bon-health');
        const data = await res.json();
        setHealth(data);
      } catch {
        setHealth(null);
      }
    };
    fetchHealth();
    const id = setInterval(fetchHealth, 5000);
    return () => clearInterval(id);
  }, []);

  const pill = (ok: boolean) => ({
    display: 'inline-block',
    width: 10,
    height: 10,
    borderRadius: '50%',
    background: ok ? '#00ff88' : '#ff3366',
    marginRight: 6,
  });

  if (!health) return <div>BoN health: loading…</div>;

  return (
    <div style={{ border: '1px solid #333', borderRadius: 4, padding: 8 }}>
      <h3>BoN Health</h3>
      <p>
        <span style={pill(health.explorerOk)} />
        Explorer: {health.explorerOk ? 'OK' : 'DOWN'}
      </p>
      <p>
        <span style={pill(health.gatewayOk)} />
        Gateway: {health.gatewayOk ? 'OK' : 'DOWN'}
      </p>
      <p style={{ fontSize: 11, opacity: 0.7 }}>
        Checked: {new Date(health.checkedAt).toLocaleTimeString()}
      </p>
    </div>
  );
};

export default BonHealth;

// FILE: scripts/bon_connectivity_test.ts
import { BON_EXPLORER_API, BON_GATEWAY_API, ADMIN_ADDRESS, TARGET_ADDRESS, SIMULATION_MODE } from '../src/config';
import fetch from 'node-fetch';
import { log } from '../src/logger';

async function testExplorer() {
  log('Testing Explorer...');
  const url = ${BON_EXPLORER_API}/accounts/${TARGET_ADDRESS}/transactions?size=5&sort=desc;
  const res = await fetch(url);
  if (!res.ok) throw new Error(Explorer error: ${res.status});
  const txs = await res.json();
  log(Explorer OK, got ${txs.length} txs);
  const adminTxs = txs.filter((tx: any) => tx.sender === ADMIN_ADDRESS);
  log(Admin→TARGET txs: ${adminTxs.length});
}

async function testGateway() {
  log('Testing Gateway...');
  const fake = {
    nonce: 0,
    value: '0',
    receiver: TARGET_ADDRESS,
    sender: ADMIN_ADDRESS,
    gasPrice: 1000000000,
    gasLimit: 50000,
    chainID: 'D',
    signature: 'SIM_SIGNATURE',
  };
  if (SIMULATION_MODE) {
    log('SIMULATION_MODE=true, not sending real tx');
    log(JSON.stringify(fake, null, 2));
    return;
  }
  const res = await fetch(${BON_GATEWAY_API}/transaction/send, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(fake),
  });
  if (!res.ok) throw new Error(Gateway error: ${res.status} ${await res.text()});
  const body = await res.json();
  log('Gateway OK, txHash:', body.data?.txHash);
}

async function main() {
  try {
    await testExplorer();
    await testGateway();
    log('All connectivity tests passed');
  } catch (e: any) {
    log('Connectivity test failed:', e.message || e);
  }
}

main();

