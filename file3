      <h3>Alerts</h3>
      {leaks.length === 0 && !highFee && <p>No alerts.</p>}
      {leaks.length > 0 && (
        <ul>
          {leaks.map(a => (
            <li key={a.id} style={{ color: '#ff3366' }}>
              Leak: {a.id} has {a.unpermitted} unpermitted txs
            </li>
          ))}
        </ul>
      )}
      {highFee && <p style={{ color: '#ffcc00' }}>Fee usage high: {guildFeeSpent.toFixed(3)} / 500 EGLD</p>}
    </div>
  );
};

export default Alerts;

